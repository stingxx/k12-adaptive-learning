// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户系统
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          UserRole
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  studentProfile StudentProfile?
  parentProfile  ParentProfile?
  
  @@index([email])
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

// ============================================
// 学生档案
// ============================================

model StudentProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName       String
  lastName        String
  grade           Int       // 1-12
  province        String    // ON, BC, AB, etc.
  dateOfBirth     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // 关系
  skillMaps       SkillMap[]
  learningHistory LearningHistory[]
  dailyPlans      DailyPlan[]
  quizAttempts    QuizAttempt[]
  
  @@index([userId])
  @@index([grade, province])
}

// ============================================
// 家长档案
// ============================================

model ParentProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName       String
  lastName        String
  phone           String?
  
  childrenIds     String[]  // 关联的学生ID列表
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

// ============================================
// 课程系统 - 加拿大K-12课程标准
// ============================================

model Subject {
  id              String    @id @default(cuid())
  name            String    @unique // Math, Science, English, Social Studies
  code            String    @unique
  description     String?
  
  curriculumNodes CurriculumNode[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CurriculumNode {
  id              String    @id @default(cuid())
  subjectId       String
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  grade           Int       // 1-12，或K
  province        String    // ON, BC, AB等，"ALL"表示全加拿大
  
  unit            String    // 如 "Numbers and Operations"
  unitOrder       Int       // 单元顺序
  
  topic           String    // 如 "Addition and Subtraction"
  topicOrder      Int       // 主题顺序
  
  description     String?
  estimatedHours  Int       @default(5)
  
  learningObjectives LearningObjective[]
  lessons         Lesson[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([subjectId, grade, province, unit, topic])
  @@index([grade, province])
  @@index([subjectId])
}

model LearningObjective {
  id              String    @id @default(cuid())
  curriculumNodeId String
  curriculumNode  CurriculumNode @relation(fields: [curriculumNodeId], references: [id], onDelete: Cascade)
  
  objective       String    // 如 "Students will be able to add two-digit numbers"
  objectiveOrder  Int
  
  blooms          String?   // Remember, Understand, Apply, Analyze, Evaluate, Create
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([curriculumNodeId])
}

// ============================================
// 课程内容（AI生成）
// ============================================

model Lesson {
  id              String    @id @default(cuid())
  curriculumNodeId String
  curriculumNode  CurriculumNode @relation(fields: [curriculumNodeId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  
  // AI生成的结构化内容
  content         Json      // { introduction, mainContent, examples, keyPoints, summary }
  
  // 难度和时长
  difficultyLevel Int       @default(1) // 1-5
  estimatedMinutes Int      @default(15)
  
  // 缓存控制
  generatedAt     DateTime  @default(now())
  expiresAt       DateTime?
  
  // 关系
  quizzes         Quiz[]
  learningHistory LearningHistory[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([curriculumNodeId])
  @@index([generatedAt])
}

// ============================================
// 测验系统
// ============================================

model Quiz {
  id              String    @id @default(cuid())
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  
  // 结构化的题目数据
  questions       Question[]
  
  // 设置
  passingScore    Int       @default(70) // 百分比
  allowRetake     Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([lessonId])
}

model Question {
  id              String    @id @default(cuid())
  quizId          String
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  questionOrder   Int
  type            QuestionType // MCQ, SHORT_ANSWER, MATH_PROBLEM
  
  question        String
  // 对于MCQ
  options         String[]  @default([])
  correctAnswer   String
  // 对于短答题
  acceptedAnswers String[]  @default([])
  // 对于数学题
  mathematicalExpression String?
  
  explanation     String?   // AI生成的解释
  difficulty      Int       @default(1) // 1-5
  
  quizAttempts    QuizAttemptAnswer[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([quizId])
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  MATH_PROBLEM
}

model QuizAttempt {
  id              String    @id @default(cuid())
  quizId          String
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  score           Int       // 百分比 0-100
  passed          Boolean
  
  answers         QuizAttemptAnswer[]
  
  startedAt       DateTime
  completedAt     DateTime  @default(now())
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([quizId, studentId])
  @@index([studentId])
  @@index([completedAt])
}

model QuizAttemptAnswer {
  id              String    @id @default(cuid())
  attemptId       String
  attempt         QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  
  questionId      String
  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  studentAnswer   String
  isCorrect       Boolean
  
  createdAt       DateTime  @default(now())
  
  @@index([attemptId, questionId])
}

// ============================================
// 学习历史 & 技能追踪
// ============================================

model SkillMap {
  id              String    @id @default(cuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  skillName       String    // 如 "Addition", "Fractions", "Photosynthesis"
  skillCategory   String    // 如 "Math", "Science"
  
  masteryLevel    Int       @default(0) // 0-100%
  attempts        Int       @default(0)
  correctAnswers  Int       @default(0)
  
  lastPracticeAt  DateTime?
  nextReviewAt    DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([studentId, skillName])
  @@index([studentId, skillCategory])
  @@index([masteryLevel])
}

model LearningHistory {
  id              String    @id @default(cuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  startedAt       DateTime
  completedAt     DateTime?
  
  timeSpentMinutes Int      @default(0)
  comprehensionScore Int?   // 0-100，基于quiz成绩
  
  createdAt       DateTime  @default(now())
  
  @@index([studentId])
  @@index([lessonId])
  @@index([completedAt])
}

// ============================================
// 每日学习计划
// ============================================

model DailyPlan {
  id              String    @id @default(cuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  planDate        DateTime  // 计划日期
  
  // 今天的4个课程
  lesson1Id       String?   // Math
  lesson2Id       String?   // Science
  lesson3Id       String?   // English
  lesson4Id       String?   // Social Studies
  
  // 完成状态
  lesson1Completed Boolean  @default(false)
  lesson2Completed Boolean  @default(false)
  lesson3Completed Boolean  @default(false)
  lesson4Completed Boolean  @default(false)
  
  // 统计
  totalTimeSpent  Int       @default(0) // 分钟
  averageScore    Int?      // 0-100
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([studentId, planDate])
  @@index([studentId, planDate])
}

// ============================================
// 自适应学习配置
// ============================================

model AdaptiveConfig {
  id              String    @id @default(cuid())
  studentId       String    @unique
  
  currentDifficulty Int     @default(2) // 1-5
  
  // 调整规则
  passingThreshold Int      @default(70) // 升级阈值
  failingThreshold Int      @default(60) // 降级阈值
  
  // 模式
  challengeMode   Boolean   @default(false) // 连续正确时启用
  consecutiveCorrect Int    @default(0)
  
  lastAdjustedAt  DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// 系统审计
// ============================================

model AuditLog {
  id              String    @id @default(cuid())
  action          String    // LOGIN, QUIZ_SUBMIT, LESSON_VIEW等
  userId          String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  
  @@index([userId, createdAt])
  @@index([action, createdAt])
}
